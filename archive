<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Turnkey CFO — Instant Estimate</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ececec;
  --surface: rgba(255,255,255,.78);
  --surface-2: rgba(255,255,255,.92);
  --navy: #042f45;
  --navy-soft: #345565;
  --green: #0edb71;
  --green-deep: #0bc664;
  --border: rgba(4,47,69,.12);
  --shadow: 0 18px 60px rgba(4,47,69,.10);
}
* { box-sizing: border-box; }
html, body { margin:0; padding:0; font-family: Inter, system-ui, sans-serif; background: radial-gradient(circle at top, #f7f7f7 0%, var(--bg) 58%); color: var(--navy); }
body { min-height:100vh; position:relative; overflow-x:hidden; }
body::before {
  content:"";
  position:fixed;
  inset:-12% -8% auto -8%;
  height:78vh;
  background:
    radial-gradient(circle at 18% 24%, rgba(14,219,113,.16), transparent 0 22%),
    radial-gradient(circle at 82% 12%, rgba(4,47,69,.11), transparent 0 25%),
    radial-gradient(circle at 50% 78%, rgba(14,219,113,.10), transparent 0 28%);
  filter: blur(10px);
  animation: driftA 18s ease-in-out infinite alternate;
  pointer-events:none;
  z-index:0;
}
body::after {
  content:"";
  position:fixed;
  inset:0;
  background:
    repeating-linear-gradient(115deg, rgba(4,47,69,.028) 0 1px, transparent 1px 34px),
    linear-gradient(180deg, rgba(255,255,255,.18), rgba(255,255,255,0));
  mask-image: linear-gradient(180deg, rgba(0,0,0,.85), rgba(0,0,0,.18) 68%, transparent 100%);
  opacity:.7;
  pointer-events:none;
  z-index:0;
}
@keyframes driftA {
  0% { transform: translate3d(0,0,0) scale(1); }
  100% { transform: translate3d(0,26px,0) scale(1.05); }
}
.shell { width:min(980px, calc(100vw - 32px)); margin:0 auto; padding:32px 0 48px; position:relative; z-index:1; }
.shell::before {
  content:"";
  position:fixed;
  width:560px;
  height:560px;
  left:-140px;
  top:120px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(14,219,113,.18) 0%, rgba(14,219,113,.10) 28%, transparent 68%);
  filter:blur(10px);
  animation: floatOrb1 16s ease-in-out infinite alternate;
  pointer-events:none;
}
.shell::after {
  content:"";
  position:fixed;
  width:620px;
  height:620px;
  right:-180px;
  bottom:40px;
  border-radius:50%;
  background:radial-gradient(circle, rgba(4,47,69,.16) 0%, rgba(4,47,69,.08) 34%, transparent 72%);
  filter:blur(12px);
  animation: floatOrb2 18s ease-in-out infinite alternate;
  pointer-events:none;
}
@keyframes floatOrb1 {
  0% { transform: translate3d(0,0,0) scale(1); }
  100% { transform: translate3d(36px,-28px,0) scale(1.08); }
}
@keyframes floatOrb2 {
  0% { transform: translate3d(0,0,0) scale(1); }
  100% { transform: translate3d(-44px,24px,0) scale(1.06); }
}
.hero { text-align:center; padding:10px 0 24px; }
.logo-wrap {
  display:flex;
  justify-content:center;
  margin:0 auto 18px;
  position:relative;
  width:min(520px, 86vw);
}
.logo-wrap img {
  width:min(460px, 80vw);
  height:auto;
  opacity:.92;
  filter: drop-shadow(0 10px 30px rgba(4,47,69,0.08));
  mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 82%, rgba(0,0,0,.18) 94%, rgba(0,0,0,0) 100%);
  -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 82%, rgba(0,0,0,.18) 94%, rgba(0,0,0,0) 100%);
}
.logo-wrap::before {
  content:"";
  position:absolute;
  inset:50% auto auto 50%;
  transform:translate(-50%, -50%);
  width:520px;
  height:300px;
  background: radial-gradient(circle, rgba(14,219,113,.11) 0%, rgba(14,219,113,.05) 36%, transparent 68%);
  filter: blur(18px);
  z-index:-1;
}
.eyebrow { letter-spacing:.24em; text-transform:uppercase; color:var(--navy-soft); font-size:12px; font-weight:700; margin-bottom:14px; }
h1 { margin:0 auto 10px; max-width:740px; font-size:clamp(34px, 5vw, 56px); line-height:.98; letter-spacing:-.05em; }
.sub { margin:0 auto; max-width:670px; color: rgba(4,47,69,.72); font-size:17px; line-height:1.6; }
.frame { background: linear-gradient(180deg, rgba(255,255,255,.84), rgba(255,255,255,.72)); backdrop-filter: blur(14px); border:1px solid var(--border); box-shadow: var(--shadow); border-radius: 32px; overflow:hidden; position:relative; }
.frame::before {
  content:"";
  position:absolute;
  inset:-18% -12% auto -12%;
  height:320px;
  background:
    radial-gradient(ellipse at 16% 40%, rgba(14,219,113,.18), transparent 0 42%),
    radial-gradient(ellipse at 78% 22%, rgba(4,47,69,.12), transparent 0 40%),
    linear-gradient(90deg, rgba(14,219,113,.06), rgba(4,47,69,.03), rgba(14,219,113,.04));
  filter: blur(6px);
  animation: driftB 18s ease-in-out infinite alternate;
  pointer-events:none;
}
.frame::after {
  content:"";
  position:absolute;
  inset:auto -6% -120px -6%;
  height:240px;
  background:
    radial-gradient(ellipse at 24% 50%, rgba(14,219,113,.16), transparent 0 36%),
    radial-gradient(ellipse at 74% 62%, rgba(4,47,69,.10), transparent 0 34%);
  filter: blur(8px);
  animation: driftC 14s ease-in-out infinite alternate;
  pointer-events:none;
}
@keyframes driftB {
  0% { transform: translateX(-2%) translateY(0); }
  100% { transform: translateX(2%) translateY(10px); }
}
@keyframes driftC {
  0% { transform: translateX(0) translateY(0) scale(1); }
  100% { transform: translateX(2%) translateY(-14px) scale(1.04); }
}
.topbar { padding:18px 24px; display:flex; justify-content:space-between; gap:12px; align-items:center; background: rgba(255,255,255,.7); border-bottom:1px solid var(--border); }
.badge { display:inline-flex; align-items:center; gap:10px; padding:10px 14px; border-radius:999px; background:rgba(4,47,69,.05); font-weight:700; font-size:13px; }
.badge .dot { width:10px; height:10px; border-radius:50%; background:var(--green); box-shadow:0 0 0 4px rgba(14,219,113,.16); }
.progress-wrap { display:flex; align-items:center; gap:12px; min-width:260px; }
.progress { flex:1; height:9px; background:rgba(4,47,69,.08); border-radius:999px; overflow:hidden; }
.bar { height:100%; width:14%; background: linear-gradient(90deg, var(--green), var(--green-deep)); border-radius:999px; transition: width .35s ease; }
.step-label { font-size:13px; font-weight:700; color:var(--navy-soft); min-width:64px; text-align:right; }
.grid { display:block; }
.panel { padding:34px; }
.main h2 { margin:0 0 12px; font-size:30px; letter-spacing:-.04em; }
.main p.lead { margin:0 0 24px; color: rgba(4,47,69,.72); line-height:1.6; font-size:16px; }
.form-step { display:none; animation: fade .22s ease; }
.form-step.active { display:block; }
@keyframes fade { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform:none; } }
.options, .toggle-group { display:grid; gap:12px; }
.options.two { grid-template-columns: repeat(2, minmax(0,1fr)); }
.options.three { grid-template-columns: repeat(3, minmax(0,1fr)); }
.options.industry-grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
.card-option { position:relative; }
.card-option input { position:absolute; inset:0; opacity:0; pointer-events:none; }
.card-option label { display:block; padding:18px 18px; border-radius:22px; border:1px solid rgba(4,47,69,.12); background:#fff; cursor:pointer; transition:.18s ease; min-height:84px; }
.card-option label strong { display:block; font-size:15px; margin-bottom:6px; }
.card-option label span { color: rgba(4,47,69,.68); font-size:13px; line-height:1.45; }
.options.industry-grid .card-option label { min-height:72px; display:flex; align-items:center; justify-content:center; text-align:center; }
.options.industry-grid .card-option label strong { margin-bottom:0; }
.card-option input:checked + label { border-color: rgba(14,219,113,.85); box-shadow: 0 0 0 4px rgba(14,219,113,.12); transform: translateY(-1px); }
.card-option label:hover { border-color: rgba(4,47,69,.22); transform: translateY(-1px); }
.field { margin-bottom:18px; }
.field label.title { display:block; font-weight:800; font-size:15px; margin-bottom:10px; }
.input, select { width:100%; appearance:none; border:1px solid rgba(4,47,69,.14); border-radius:16px; padding:16px 15px; font-size:15px; color:var(--navy); background:#fff; outline:none; transition:.18s ease; }
.input:focus, select:focus { border-color: rgba(14,219,113,.9); box-shadow:0 0 0 4px rgba(14,219,113,.12); }
.helper { margin-top:8px; color: rgba(4,47,69,.56); font-size:12px; }
.row-2 { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:14px; }
.nav { display:flex; justify-content:space-between; gap:12px; margin-top:26px; }
.btn { border:none; border-radius:16px; padding:16px 20px; font-size:15px; font-weight:800; cursor:pointer; transition:.18s ease; }
.btn.secondary { background: rgba(4,47,69,.06); color: var(--navy); }
.btn.secondary:hover { background: rgba(4,47,69,.10); }
.btn.primary { background: var(--navy); color:#fff; box-shadow:0 14px 24px rgba(4,47,69,.14); }
.btn.primary:hover { transform: translateY(-1px); background:#02293d; }
.btn.accent { background: linear-gradient(90deg, var(--green), var(--green-deep)); color:#072d3d; }
.btn.accent:hover { transform: translateY(-1px); }
.hidden { display:none !important; }
.result-wrap { display:none; padding:38px; background: var(--surface-2); }
.result-wrap.active { display:block; animation: fade .24s ease; }
.result-head { display:flex; justify-content:space-between; gap:16px; align-items:flex-start; margin-bottom:24px; }
.result-head h2 { margin:0 0 10px; font-size:34px; letter-spacing:-.04em; }
.result-head p { margin:0; max-width:680px; color: rgba(4,47,69,.72); line-height:1.65; }
.result-card-grid { display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:16px; margin:22px 0 26px; }
.result-card { padding:22px; border-radius:24px; background:#fff; border:1px solid rgba(4,47,69,.10); box-shadow:0 10px 24px rgba(4,47,69,.06); }
.result-card .k { font-size:12px; letter-spacing:.16em; text-transform:uppercase; color:var(--navy-soft); font-weight:800; margin-bottom:10px; }
.result-card .v { font-size:clamp(26px,4vw,36px); font-weight:800; letter-spacing:-.05em; }
.result-card .s { margin-top:10px; color: rgba(4,47,69,.7); font-size:13px; line-height:1.55; }
.result-card.highlight { background: linear-gradient(180deg, rgba(14,219,113,.10), rgba(255,255,255,.98)); border-color: rgba(14,219,113,.28); }
.note-box { display:grid; grid-template-columns: 1.05fr .95fr; gap:16px; }
.note { padding:20px 22px; background:#fff; border:1px solid rgba(4,47,69,.10); border-radius:22px; }
.note h4 { margin:0 0 10px; font-size:15px; text-transform:uppercase; letter-spacing:.14em; color:var(--navy-soft); }
.note p, .note ul { margin:0; color: rgba(4,47,69,.72); font-size:14px; line-height:1.7; }
.note li + li { margin-top:6px; }
.note ul { padding-left:18px; }
.cta-row { display:flex; gap:12px; margin-top:20px; flex-wrap:wrap; }
.footer-mini { text-align:center; color: rgba(4,47,69,.58); font-size:12px; padding:18px 12px 0; }
@media (max-width: 860px) {
  .note-box, .result-card-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  .shell { width:min(100vw - 20px, 980px); padding-top:18px; }
  .panel, .result-wrap { padding:22px; }
  .topbar { padding:14px 16px; flex-direction:column; align-items:stretch; }
  .options.two, .options.three, .options.industry-grid, .row-2 { grid-template-columns:1fr; }
  .badge { justify-content:center; }
  .logo-wrap img { width:min(360px, 84vw); }
}
</style>
</head>
<body>
  <div class="shell">
    <section class="hero">
      <div class="logo-wrap"><img alt="Turnkey CFO" src="data:image/png;base64," /></div>
      <div class="eyebrow">Instant Estimate Experience</div>
      <h1>See what your monthly finance support could look like.</h1>
      <p class="sub">A free and quick way to have a custom quote tailored for your business needs.</p>
    </section>

    <section class="frame">
      <div class="topbar" id="formTopbar">
        <div class="badge"><span class="dot"></span> Premium estimate in under 1 minute</div>
        <div class="progress-wrap">
          <div class="progress"><div class="bar" id="progressBar"></div></div>
          <div class="step-label" id="stepLabel">1 / 5</div>
        </div>
      </div>

      <div class="grid" id="formGrid">
        <div class="panel main">
          <form id="quoteForm">
            <div class="form-step active" data-step="1">
              <h2>Start with the shape of the business.</h2>
              <div class="field">
                <label class="title" for="companyName">Company name</label>
                <input class="input" id="companyName" name="companyName" type="text" placeholder="Your company name" required />
              </div>
              <div class="field">
                <label class="title">Industry</label>
                <div class="options industry-grid">
                  <div class="card-option"><input type="radio" name="industry" id="ind-church" value="church" required><label for="ind-church"><strong>Church / NonProfit</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-construction" value="construction"><label for="ind-construction"><strong>Construction</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-ecommerce" value="other"><label for="ind-ecommerce"><strong>Ecommerce</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-saas" value="other"><label for="ind-saas"><strong>SaaS</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-realestate" value="other"><label for="ind-realestate"><strong>Real Estate</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-finserv" value="other"><label for="ind-finserv"><strong>Financial Services</strong></label></div>
                  <div class="card-option"><input type="radio" name="industry" id="ind-other" value="other"><label for="ind-other"><strong>Other</strong></label></div>
                </div>
              </div>
              <div class="field hidden" id="otherIndustryWrap">
                <label class="title" for="otherIndustryName">Tell us your industry</label>
                <input class="input" id="otherIndustryName" name="otherIndustryName" type="text" placeholder="Optional" />
              </div>
              <div class="row-2">
                <div class="field">
                  <label class="title" for="revenue">Annual revenue</label>
                  <select id="revenue" name="revenue" required>
                    <option value="" disabled selected>Select a range</option>
                    <option value="lt250">Under $250k</option>
                    <option value="250to1m">$250k - $1M</option>
                    <option value="1to3m">$1M - $3M</option>
                    <option value="gt3m">$3M+</option>
                  </select>
                </div>
                <div class="field">
                  <label class="title" for="software">Accounting software</label>
                  <select id="software" name="software" required>
                    <option value="" disabled selected>Select software</option>
                    <option value="quickbooks">QuickBooks</option>
                    <option value="xero">Xero</option>
                    <option value="zoho">Zoho Books</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-step" data-step="software-other">
              <h2>Tell us the accounting tool you use.</h2>
              <p class="lead">This helps us flag any migration or workflow considerations before we finalize scope.</p>
              <div class="field">
                <label class="title" for="otherSoftwareName">Accounting tool name</label>
                <input class="input" id="otherSoftwareName" name="otherSoftwareName" type="text" placeholder="Enter your accounting software" />
              </div>
            </div>

            <div class="form-step" data-step="2">
              <h2>Next, tell us about complexity.</h2>
              <p class="lead">A few simple inputs help us estimate how much hands-on management your books will need each month.</p>
              <div class="row-2">
                <div class="field">
                  <label class="title" for="accountCount">Total bank + credit card accounts</label>
                  <select id="accountCount" name="accountCount" required>
                    <option value="le5">5 or fewer</option>
                    <option value="6to10">6 - 10</option>
                    <option value="gt10">11+</option>
                  </select>
                </div>
              </div>
              <div class="row-2">
                <div class="field">
                  <label class="title" for="inventory">Inventory tracking?</label>
                  <select id="inventory" name="inventory" required>
                    <option value="no">No</option>
                    <option value="yes">Yes</option>
                  </select>
                </div>
              </div>
            </div>

            <div class="form-step" data-step="3">
              <h2>Choose the support you want each month.</h2>
              <p class="lead">Your bookkeeping estimate starts at a base fee, then builds only where extra service is needed.</p>
              <div class="field">
                <label class="title">Payroll support</label>
                <div class="options three">
                  <div class="card-option"><input type="radio" name="payroll" id="pay-none" value="none" required><label for="pay-none"><strong>No payroll</strong><span>No payroll administration needed.</span></label></div>
                  <div class="card-option"><input type="radio" name="payroll" id="pay-simple" value="simple"><label for="pay-simple"><strong>Simple payroll</strong><span>W-2 payroll only.</span></label></div>
                  <div class="card-option"><input type="radio" name="payroll" id="pay-complex" value="complex"><label for="pay-complex"><strong>Payroll +</strong><span>Multi-state or more involved payroll support.</span></label></div>
                </div>
              </div>
              <div class="row-2">
                <div class="field">
                  <label class="title" for="billpay">Bill pay / AP support</label>
                  <select id="billpay" name="billpay" required>
                    <option value="none">No</option>
                    <option value="lt40">Yes — under 40 bills/month</option>
                    <option value="40to100">Yes — 40 to 100 bills/month</option>
                    <option value="gt100">Yes — 100+ bills/month</option>
                  </select>
                </div>
                <div class="field construction-only hidden" id="jobCostWrap">
                  <label class="title" for="jobCosting">Need job costing?</label>
                  <select id="jobCosting" name="jobCosting">
                    <option value="no">No</option>
                    <option value="yes">Yes</option>
                  </select>
                </div>
              </div>
              <div class="field">
                <label class="title">Would you like to explore broader CFO advisory support?</label>
                <div class="toggle-group">
                  <div class="card-option"><input type="checkbox" name="advisory_budgeting" id="advisory_budgeting" value="yes"><label for="advisory_budgeting"><strong>Budgeting</strong><span>Planning support and budget development.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_forecasting" id="advisory_forecasting" value="yes"><label for="advisory_forecasting"><strong>Forecasting</strong><span>Cash flow or forward-looking planning.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_kpi" id="advisory_kpi" value="yes"><label for="advisory_kpi"><strong>KPI dashboarding</strong><span>Metrics, dashboards, and performance visibility.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_ma" id="advisory_ma" value="yes"><label for="advisory_ma"><strong>M&amp;A</strong><span>Transaction readiness or deal support.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_exit" id="advisory_exit" value="yes"><label for="advisory_exit"><strong>Exit planning</strong><span>Positioning for a future sale or transition.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_capital" id="advisory_capital" value="yes"><label for="advisory_capital"><strong>Capital strategy</strong><span>Debt, equity, fundraising, or capital structure.</span></label></div>
                  <div class="card-option"><input type="checkbox" name="advisory_other" id="advisory_other" value="yes"><label for="advisory_other"><strong>Other CFO advisory</strong><span>Additional strategic finance support.</span></label></div>
                </div>
              </div>
            </div>
            </div>

            <div class="form-step" data-step="4">
              <h2>How current are the books today?</h2>
              <p class="lead">We estimate catch-up work separately so your monthly service quote stays clean.</p>
              <div class="field">
                <label class="title" for="monthsBehind">Months behind</label>
                <select id="monthsBehind" name="monthsBehind" required>
                  <option value="0">Current / no cleanup needed</option>
                  <option value="1">1 month</option>
                  <option value="2">2 months</option>
                  <option value="3">3 months</option>
                  <option value="4">4 months</option>
                  <option value="5">5 months</option>
                  <option value="6">6 months</option>
                  <option value="7">7+ months</option>
                </select>
                <div class="helper">Cleanup is estimated separately using your monthly service level as the base.</div>
              </div>
            </div>

            <div class="form-step" data-step="5">
              <h2>One last detail before we reveal your estimate.</h2>
              <p class="lead">Enter your email and we’ll surface your custom estimate on the next screen.</p>
              <div class="field">
                <label class="title" for="email">Email address</label>
                <input class="input" id="email" name="email" type="email" placeholder="you@company.com" required />
              </div>
            </div>

            <div class="nav">
              <button type="button" class="btn secondary" id="backBtn">Back</button>
              <button type="button" class="btn primary" id="nextBtn">Continue</button>
              <button type="submit" class="btn accent hidden" id="submitBtn">See my estimate</button>
            </div>
          </form>
        </div>
      </div>

      <section class="result-wrap" id="resultWrap">
        <div class="result-head">
          <div>
            <div class="eyebrow" style="margin-bottom:12px;">Your estimate is ready</div>
            <h2>Here’s your projected range.</h2>
            <p id="narrative">Based on your inputs, this is the estimated range for recurring monthly support plus a separate cleanup estimate.</p>
          </div>
        </div>

        <div class="result-card-grid">
          <div class="result-card highlight">
            <div class="k">Monthly services</div>
            <div class="v" id="monthlyRange">$0 - $0</div>
            <div class="s">Your projected recurring monthly range based on the services and complexity selected.</div>
          </div>
          <div class="result-card">
            <div class="k">Cleanup estimate</div>
            <div class="v" id="cleanupFee">$0</div>
            <div class="s">Shown separately so monthly service pricing stays clean and predictable.</div>
          </div>
          <div class="result-card">
            <div class="k">Review status</div>
            <div class="v" id="reviewStatus">Looks standard</div>
            <div class="s" id="reviewSub">No major complexity flags were triggered by your responses.</div>
          </div>
        </div>

        <div class="note-box">
          <div class="note">
            <h4>Estimate summary</h4>
            <ul id="estimateSummary"></ul>
          </div>
          <div class="note">
            <h4>What happens next</h4>
            <p>This estimate is designed to give you a practical planning range. The next step is a short intro call so we can confirm fit, answer questions, and turn this into a finalized proposal if needed.</p>
            <div class="cta-row">
              <a class="btn accent" href="https://calendly.com/ricky-turnkeycfo/15min-intro-call" target="_blank" rel="noopener noreferrer" style="text-decoration:none; display:inline-flex; align-items:center; justify-content:center;">Book 15min Review Call</a>
              <button class="btn secondary" type="button" id="restartBtn">Start over</button>
            </div>
          </div>
        </div>
      </section>
    </section>

    <div class="footer-mini">Turnkey CFO — estimate ranges are directional and subject to final review.</div>
  </div>

<script>
const steps = Array.from(document.querySelectorAll('.form-step'));
const progressBar = document.getElementById('progressBar');
const stepLabel = document.getElementById('stepLabel');
const nextBtn = document.getElementById('nextBtn');
const backBtn = document.getElementById('backBtn');
const submitBtn = document.getElementById('submitBtn');
const form = document.getElementById('quoteForm');
const resultWrap = document.getElementById('resultWrap');
const formGrid = document.getElementById('formGrid');
const formTopbar = document.getElementById('formTopbar');
const restartBtn = document.getElementById('restartBtn');
const industryInputs = document.querySelectorAll('input[name="industry"]');
const jobCostWrap = document.getElementById('jobCostWrap');
const otherIndustryWrap = document.getElementById('otherIndustryWrap');
let currentStep = 0;

function activeSteps() {
  const software = document.getElementById('software')?.value;
  return steps.filter(step => !(step.dataset.step === 'software-other' && software !== 'other'));
}

function updateJobCostVisibility() {
  const selected = document.querySelector('input[name="industry"]:checked');
  const isConstruction = selected && selected.value === 'construction';
  const isOther = selected && selected.id === 'ind-other';
  jobCostWrap.classList.toggle('hidden', !isConstruction);
  otherIndustryWrap.classList.toggle('hidden', !isOther);
  if (!isConstruction) document.getElementById('jobCosting').value = 'no';
  if (!isOther) document.getElementById('otherIndustryName').value = '';
}
industryInputs.forEach(input => input.addEventListener('change', updateJobCostVisibility));

function validateStep(index) {
  const stepList = activeSteps();
  const fields = stepList[index].querySelectorAll('input, select');
  for (const field of fields) {
    if (field.closest('.hidden')) continue;
    if (field.type === 'radio') {
      const group = stepList[index].querySelectorAll(`input[name="${field.name}"]`);
      if (![...group].some(el => el.checked)) return false;
    } else if (field.hasAttribute('required') && !field.value) {
      return false;
    }
  }
  return true;
}

function renderStep() {
  const stepList = activeSteps();
  const currentStepEl = stepList[currentStep];
  steps.forEach(step => step.classList.toggle('active', step === currentStepEl));
  const pct = ((currentStep + 1) / stepList.length) * 100;
  progressBar.style.width = pct + '%';
  stepLabel.textContent = `${currentStep + 1} / ${stepList.length}`;
  backBtn.style.visibility = currentStep === 0 ? 'hidden' : 'visible';
  const last = currentStep === stepList.length - 1;
  nextBtn.classList.toggle('hidden', last);
  submitBtn.classList.toggle('hidden', !last);
}

nextBtn.addEventListener('click', () => {
  if (!validateStep(currentStep)) {
    alert('Please complete this step before continuing.');
    return;
  }
  const stepList = activeSteps();
  const currentStepEl = stepList[currentStep];
  if (currentStepEl?.dataset.step === 'software-other') {
    const otherSoftwareInput = document.getElementById('otherSoftwareName');
    if (!otherSoftwareInput.value.trim()) {
      alert('Please enter the accounting tool you use.');
      otherSoftwareInput.focus();
      return;
    }
  }
  currentStep = Math.min(currentStep + 1, stepList.length - 1);
  renderStep();
});
backBtn.addEventListener('click', () => {
  currentStep = Math.max(currentStep - 1, 0);
  renderStep();
});

document.getElementById('software').addEventListener('change', () => {
  const stepList = activeSteps();
  if (currentStep >= stepList.length) currentStep = stepList.length - 1;
  renderStep();
});

function money(n) {
  return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
}

function calculateEstimate(data) {
  let monthly = 300;
  const flags = [];

  const revenueAdj = { lt250: -50, '250to1m': 0, '1to3m': 150, gt3m: 300 }[data.revenue] || 0;
  monthly += revenueAdj;

  const accountAdj = { le5: 0, '6to10': 50, gt10: 100 }[data.accountCount] || 0;
  monthly += accountAdj;

  const industryAdj = { other: 0, church: -100, construction: 100 }[data.industry] || 0;
  monthly += industryAdj;

  const payrollAdj = { none: 0, simple: 100, complex: 300 }[data.payroll] || 0;
  monthly += payrollAdj;

  const billAdj = { none: 0, lt40: 100, '40to100': 250, gt100: 350 }[data.billpay] || 0;
  monthly += billAdj;
  if (data.industry === 'construction' && data.jobCosting === 'yes') monthly += 50;

  monthly += 50;
  monthly = Math.max(350, monthly);
  const low = Math.max(350, monthly - 75);
  const high = Math.max(monthly + 75, low + 150);

  let cleanup = 0;
  const monthsBehind = parseInt(data.monthsBehind, 10) || 0;
  if (monthsBehind > 0) {
    const mult = monthsBehind >= 6 ? 0.4 : 0.5;
    cleanup = monthly * mult * monthsBehind;
  }

  if (data.software === 'other') flags.push('non-standard accounting software');
  if (data.inventory === 'yes') flags.push('inventory tracking');
  if (monthsBehind >= 6) flags.push('6+ months of cleanup');

  return { monthly, low, high, cleanup, flags };
}

form.addEventListener('submit', (e) => {
  e.preventDefault();
  if (!validateStep(currentStep)) {
    alert('Please complete this step before seeing your estimate.');
    return;
  }
  const fd = new FormData(form);
  const data = Object.fromEntries(fd.entries());
  data.advisory_budgeting = fd.get('advisory_budgeting') === 'yes';
  data.advisory_forecasting = fd.get('advisory_forecasting') === 'yes';
  data.advisory_kpi = fd.get('advisory_kpi') === 'yes';
  data.advisory_ma = fd.get('advisory_ma') === 'yes';
  data.advisory_exit = fd.get('advisory_exit') === 'yes';
  data.advisory_capital = fd.get('advisory_capital') === 'yes';
  data.advisory_other = fd.get('advisory_other') === 'yes';
  const result = calculateEstimate(data);

  document.getElementById('monthlyRange').textContent = `${money(result.low)} - ${money(result.high)}`;
  document.getElementById('cleanupFee').textContent = result.cleanup > 0 ? money(result.cleanup) : 'None implied';

  const reviewStatus = document.getElementById('reviewStatus');
  const reviewSub = document.getElementById('reviewSub');
  if (result.flags.length) {
    reviewStatus.textContent = 'Review suggested';
    reviewSub.textContent = 'The estimate still works, but a few items deserve a quick follow-up: ' + result.flags.join(', ') + '.';
  } else {
    reviewStatus.textContent = 'Looks standard';
    reviewSub.textContent = 'No major complexity flags were triggered by your responses.';
  }

  let industryLabel = 'Other';
  const selectedIndustryEl = document.querySelector('input[name="industry"]:checked + label strong');
  if (selectedIndustryEl) industryLabel = selectedIndustryEl.textContent;
  const payrollLabel = { none:'no payroll support', simple:'simple payroll', complex:'Payroll +' }[data.payroll];
  const billLabel = { none:'no bill pay support', lt40:'bill pay under 40 bills/month', '40to100':'bill pay for 40 to 100 bills/month', gt100:'bill pay above 100 bills/month' }[data.billpay];
  const advisorySelections = [];
  if (data.advisory_budgeting) advisorySelections.push('Budgeting');
  if (data.advisory_forecasting) advisorySelections.push('Forecasting');
  if (data.advisory_kpi) advisorySelections.push('KPI dashboarding');
  if (data.advisory_ma) advisorySelections.push('M&A');
  if (data.advisory_exit) advisorySelections.push('Exit planning');
  if (data.advisory_capital) advisorySelections.push('Capital strategy');
  if (data.advisory_other) advisorySelections.push('Other CFO advisory');

  document.getElementById('narrative').textContent = `Based on your inputs, this estimate combines a $300 bookkeeping base with added services and light complexity adjustments. The result is a monthly range plus a separate cleanup estimate.`;
  const estimateSummary = document.getElementById('estimateSummary');
  const revenueLabel = data.revenue === 'lt250' ? 'Under $250k' : data.revenue === '250to1m' ? '$250k to $1M' : data.revenue === '1to3m' ? '$1M to $3M' : '$3M+';
  const accountLabel = data.accountCount === 'le5' ? '5 or fewer financial accounts' : data.accountCount === '6to10' ? '6 to 10 financial accounts' : '11+ financial accounts';
  const cleanupLabel = parseInt(data.monthsBehind, 10) > 0 ? `${data.monthsBehind === '7' ? '7+' : data.monthsBehind} month(s) behind` : 'Current books / no cleanup indicated';
  const softwareLabel = data.software === 'quickbooks' ? 'QuickBooks' : data.software === 'xero' ? 'Xero' : data.software === 'zoho' ? 'Zoho Books' : (data.otherSoftwareName?.trim() || 'Other');
  const displayIndustry = (document.getElementById('otherIndustryName')?.value.trim() && document.getElementById('ind-other').checked) ? document.getElementById('otherIndustryName').value.trim() : industryLabel;
  const summaryItems = [
    `Company name: ${data.companyName}`,
    `Industry: ${displayIndustry}`,
    `Annual revenue: ${revenueLabel}`,
    `Accounting software: ${softwareLabel}`,
    `Complexity: ${accountLabel}`,
    `Inventory tracking: ${data.inventory === 'yes' ? 'Yes' : 'No'}`,
    `Payroll support: ${payrollLabel}`,
    `Bill pay / AP: ${billLabel}`,
    `CFO advisory interest: ${advisorySelections.length ? advisorySelections.join(', ') : 'None selected'}`,
    `Cleanup status: ${cleanupLabel}`
  ];
  if (data.industry === 'construction') {
    summaryItems.splice(9, 0, `Job costing: ${data.jobCosting === 'yes' ? 'Yes' : 'No'}`);
  }
  estimateSummary.innerHTML = summaryItems.map(item => `<li>${item}</li>`).join('');

  formGrid.classList.add('hidden');
  formTopbar.classList.add('hidden');
  resultWrap.classList.add('active');
  resultWrap.scrollIntoView({ behavior:'smooth', block:'start' });
});

restartBtn.addEventListener('click', () => {
  form.reset();
  currentStep = 0;
  updateJobCostVisibility();
  renderStep();
  formGrid.classList.remove('hidden');
  formTopbar.classList.remove('hidden');
  resultWrap.classList.remove('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

updateJobCostVisibility();
renderStep();
</script>
</body>
</html>
